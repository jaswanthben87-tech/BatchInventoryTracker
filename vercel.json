{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/src/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/_/backend/(.*)", "dest": "/backend/src/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
